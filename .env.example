GRAFANA_DOMAIN=grafana.example.com
GRAFANA_ROOT_URL=https://grafana.example.com
GRAFANA_HEALTH_URL=http://localhost:3000/api/health
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-this-before-deploy

REMOTE_LOG_TOKEN=change-this-to-a-long-random-token
REMOTE_LOG_GATEWAY_URL=https://logs.example.com

LOKI_URL=http://loki:3100
LOKI_PUSH_URL=http://loki:3100/loki/api/v1/push
LOKI_READY_URL=http://localhost:3100/ready
LOKI_HTTP_LISTEN_PORT=3100
LOKI_GRPC_LISTEN_PORT=9095

TEMPO_URL=http://tempo:3200
TEMPO_OTLP_HTTP_URL=http://tempo:4318
TEMPO_OTLP_GRPC_ENDPOINT=tempo:4317
TEMPO_READY_URL=http://localhost:3200/ready
TEMPO_HTTP_LISTEN_PORT=3200
TEMPO_OTLP_HTTP_LISTEN_ENDPOINT=0.0.0.0:4318
TEMPO_OTLP_GRPC_LISTEN_ENDPOINT=0.0.0.0:4317

PROMETHEUS_URL=http://prometheus:9090
PROMETHEUS_HEALTH_URL=http://localhost:9090/-/healthy
PROMETHEUS_SELF_TARGET=localhost:9090
LOKI_METRICS_TARGET=loki:3100
TEMPO_METRICS_TARGET=tempo:3200
ALLOY_METRICS_TARGET=alloy:12345
GRAFANA_METRICS_TARGET=grafana:3000

LOKI_RETENTION=2160h
TEMPO_RETENTION=2160h
PROMETHEUS_RETENTION=2160h

ALLOY_IMAGE=grafana/alloy:v1.9.2
CADDY_IMAGE=caddy:2.10.2-alpine
LOKI_IMAGE=grafana/loki:3.5.1
TEMPO_IMAGE=grafana/tempo:2.8.1
PROMETHEUS_IMAGE=quay.io/prometheus/prometheus:v3.4.2
GRAFANA_IMAGE=grafana/grafana:12.0.2
